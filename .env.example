# Copy this file to .env and fill in your own keys. Never commit .env.
GOOGLE_API_KEY=your-gemini-api-key-here

# Optional: only needed if Gemini errors (quota/access/model-not-found) — the
# CLI automatically falls back to this provider for the session.
# Free key, no credit card: console.groq.com
GROQ_API_KEY=your-groq-api-key-here

# Optional overrides:
# GEMINI_MODEL=gemini-2.0-flash
# FALLBACK_MODEL=groq/llama-3.3-70b-versatile
# MAX_TOPIC_LENGTH=200
# MCP_RATE_LIMIT_PER_MINUTE=30
